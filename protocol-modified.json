          "variable": "afc2543a-bf2a-4280-8185-544d5e13b78d",
          "color": "ord-color-seq-4",
          "id": "f1763a9a-b48a-44df-95dd-e60f5489d344",
          "text": "To what extent did each person provide information and discuss options?\n"
        },
        {
          "variable": "8b41bcc2-4ab2-42e4-a3bd-ade50fbb229d",
          "color": "ord-color-seq-4",
          "id": "f943f5a2-edef-41be-bb2d-b05bd963d519",
          "text": "To what extent did each person tell you to stop thinking about the incident?\n"
        },
        {
          "variable": "78504f45-ec0a-40e9-b911-d575524b9e9f",
          "color": "ord-color-seq-4",
          "id": "4551e1c9-5465-4490-91ed-f2aabc96d8fb",
          "text": "To what extent did each person make you feel like you didn't know how to take care of yourself?\n"
        }
